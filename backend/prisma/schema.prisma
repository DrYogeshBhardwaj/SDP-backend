generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String          @id @default(uuid())
  mobile                String          @unique
  name                  String?
  avatar                String?         // Base64 or URL
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  status                Status          @default(ACTIVE)
  role                  Role            @default(PARTNER)
  referralCode          String?         @unique
  sponsorId             String?
  
  // V1 Therapy Stats
  minutesBalance        Int             @default(3600)
  dailyMinutesUsed      Int             @default(0)
  totalMinutesConsumed  Int             @default(0)
  lastSessionAt         DateTime?
  streak                Int             @default(0)
  
  // MLM Goal / Lock Settings
  goalType              String?         // MAN, TAN, DHAN, STABILITY, CUSTOM
  goalPlanets           String?         // Comma separated Planet IDs
  goalLockUntil         DateTime?

  // Relations
  wallets               Wallet[]
  transactions          Transaction[]   @relation("UserTransactions")
  sourceTransactions    Transaction[]   @relation("SourceTransactions")
  payouts               Payout[]
  sessions              TherapySession[]
  supportQueries        SupportQuery[]
  upiId                 String?
  
  // Self-relation for MLM levels
  sponsor               User?           @relation("SponsorRelation", fields: [sponsorId], references: [id])
  referrals             User[]          @relation("SponsorRelation")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String
  type      String   // CASH, MINUTE
  balance   Float    @default(0)
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserTransactions", fields: [userId], references: [id])
  fromUserId  String?
  fromUser    User?    @relation("SourceTransactions", fields: [fromUserId], references: [id])
  amount      Float
  type        String   // CREDIT, DEBIT
  category    String?   // BONUS, PURCHASE, PAYOUT, DEDUCTION
  description String?
  createdAt   DateTime @default(now())
}

model Payout {
  id           String       @id @default(uuid())
  userId       String
  amount       Float
  status       PayoutStatus @default(PENDING)
  transactionId String?
  createdAt    DateTime     @default(now())
  processedAt  DateTime?
  user         User         @relation(fields: [userId], references: [id])
}

model TherapySession {
  id          String   @id @default(uuid())
  userId      String
  duration    Int      // minutes requested
  minutesUsed Int?
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, ABANDONED
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  user        User     @relation(fields: [userId], references: [id])
}

model OtpSession {
  id        String   @id @default(uuid())
  mobile    String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PaymentOrder {
  id        String   @id @default(uuid())
  mobile    String
  amount    Float
  orderId   String   @unique
  status    String   @default("CREATED") // CREATED, PAID
  createdAt DateTime @default(now())
}

model SupportQuery {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  message   String
  response  String?
  status    String   @default("PENDING") // PENDING, RESOLVED
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  PARTNER
  ADMIN
  SUPPORT
}

enum Status {
  ACTIVE
  BLOCKED
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
